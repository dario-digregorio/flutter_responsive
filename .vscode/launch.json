{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "app debug",
            "request": "launch",
            "type": "dart",
            // "cwd": "${workspaceFolder}\\app",
            "program": "${workspaceFolder}\\app\\lib\\main.dart"
        },
        {
            "name": "deck debug",
            "request": "launch",
            "type": "dart",
            // "cwd": "${workspaceFolder}\\deck",
            "program": "${workspaceFolder}\\deck\\lib\\main.dart"
        },
        {
            "name": "flutter_responsive (profile mode)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "profile",
            "cwd": "${workspaceFolder}\\app",
        },
        {
            "name": "flutter_responsive (release mode)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "release",
            "cwd": "${workspaceFolder}\\app",
        }
    ]
}